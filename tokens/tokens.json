{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "brand": { "$value": "Organica Black — Nature & More", "$type": "string" },
  "color": {
    "purple": {
      "400": { "$value": "#8b65c2", "$type": "color", "$description": "Light purple — hsl(264, 43%, 58%)" },
      "500": { "$value": "#7045af", "$type": "color", "$description": "Primary brand purple — hsl(264, 43%, 48%)" },
      "600": { "$value": "#59378a", "$type": "color", "$description": "Dark purple — hsl(264, 43%, 38%)" }
    },
    "neutral": {
      "black": { "$value": "#111111", "$type": "color", "$description": "Brand black — hsl(0, 0%, 7%)" },
      "gray-900": { "$value": "#2a2a2a", "$type": "color", "$description": "Dark gray — hsl(0, 0%, 17%)" },
      "white": { "$value": "#ffffff", "$type": "color" }
    },
    "semantic": {
      "primary": { "$value": "{color.purple.500}", "$type": "color" },
      "primary-hover": { "$value": "{color.purple.600}", "$type": "color" },
      "primary-subtle": { "$value": "{color.purple.400}", "$type": "color" },
      "text": { "$value": "{color.neutral.black}", "$type": "color" },
      "text-secondary": { "$value": "{color.neutral.gray-900}", "$type": "color" },
      "text-on-primary": { "$value": "{color.neutral.white}", "$type": "color" },
      "background": { "$value": "{color.neutral.white}", "$type": "color" },
      "background-inverse": { "$value": "{color.purple.500}", "$type": "color" }
    }
  },
  "font": {
    "family": {
      "heading": { "$value": "'Alata', sans-serif", "$type": "fontFamily", "$description": "Display / headings. Google Fonts: Alata" },
      "body": { "$value": "'Roboto Slab', serif", "$type": "fontFamily", "$description": "Body copy. Google Fonts: Roboto Slab" }
    },
    "weight": {
      "regular": { "$value": 400, "$type": "fontWeight", "$description": "Both brand fonts ship in Regular 400; use size and color for hierarchy" }
    },
    "size": {
      "xs": { "$value": "0.75rem", "$type": "dimension" },
      "sm": { "$value": "0.875rem", "$type": "dimension" },
      "base": { "$value": "1rem", "$type": "dimension" },
      "lg": { "$value": "1.25rem", "$type": "dimension" },
      "xl": { "$value": "1.5rem", "$type": "dimension" },
      "2xl": { "$value": "2rem", "$type": "dimension" },
      "3xl": { "$value": "3rem", "$type": "dimension" },
      "display": { "$value": "4.5rem", "$type": "dimension", "$description": "Large section titles, as used in the guideline headers" }
    },
    "letter-spacing": {
      "wordmark-caps": { "$value": "0.3em", "$type": "dimension", "$description": "Tracking for the NATURE & MORE tagline style" }
    }
  },
  "logo": {
    "clear-space": { "$value": "Height of the tree mark on all sides", "$type": "string" },
    "usage": {
      "full-color": { "$value": "White backgrounds only", "$type": "string" },
      "white": { "$value": "Photos and colored backgrounds", "$type": "string" },
      "black": { "$value": "Light colored backgrounds", "$type": "string" },
      "never": { "$value": "Do not rotate, distort, partially cover, or place the full-color logo directly on a photo", "$type": "string" }
    }
  }
}
